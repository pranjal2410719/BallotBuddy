# ============================================================
# BallotBuddy — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is blocked by .gitignore.
#
# cp .env.local.example .env.local
# ============================================================

# ------------------------------
# Google Gemini API Key (REQUIRED)
# ------------------------------
# Powers the AI chat assistant with 5 personas and voice support.
# Get your free key at: https://aistudio.google.com/apikey
# The free tier is sufficient for development and demos.
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
